{
	"name": "hazel-chat",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"libs/*",
			"bots/*"
		],
		"catalogs": {
			"effect": {
				"effect": "4.0.0-beta.57",
				"@effect/platform-bun": "4.0.0-beta.57",
				"@effect/platform-browser": "4.0.0-beta.57",
				"@effect/platform-node": "4.0.0-beta.57",
				"@effect/sql-pg": "4.0.0-beta.57",
				"@effect/opentelemetry": "4.0.0-beta.57",
				"@effect/atom-react": "4.0.0-beta.57",
				"@effect/ai-openrouter": "4.0.0-beta.57",
				"@effect/vitest": "4.0.0-beta.57"
			}
		}
	},
	"scripts": {
		"dev:withBots": "turbo dev",
		"dev": "turbo run dev --filter='*' --filter='!./bots/*'",
		"dev:bots": "turbo run dev --filter='@hazel/bot-gateway' --filter='./bots/*'",
		"build": "turbo build typecheck",
		"start": "turbo start",
		"setup": "bun run packages/setup/src/index.ts",
		"setup:turbo": "turbo setup",
		"typecheck": "turbo build typecheck",
		"format": "oxfmt",
		"lint": "oxlint",
		"test": "vitest",
		"test:once": "vitest run",
		"test:debug": "vitest --inspect-brk --no-file-parallelism",
		"test:coverage": "vitest run --coverage --coverage.reporter=text"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@rolldown/plugin-babel": "^0.2.1",
		"@vitest/coverage-v8": "^4.1.0",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0",
		"rollup-plugin-visualizer": "7.0.1",
		"turbo": "^2.8.16",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0",
		"web": "workspace:*",
		"wrangler": "^4.73.0"
	},
	"engines": {
		"bun": ">=1.2.14"
	},
	"packageManager": "bun@1.3.10",
	"trustedDependencies": []
}
