# Database Configuration
# Local Docker PostgreSQL (recommended for development)
DATABASE_URL=postgresql://user:password@localhost:5432/app
IS_DEV=true

# For production/remote database, use:
# DATABASE_URL=postgresql://user:password@your-db-host:6432/postgres?sslmode=verify-full

# Redis (for rate limiting)
# Uses the cache_redis service from docker-compose.yaml
REDIS_URL=redis://localhost:6380
