# Backend API URL
# Local backend service (Docker)
VITE_BACKEND_URL=http://localhost:3003

# Cluster Service URL
# Local cluster service (Docker)
VITE_CLUSTER_URL=http://localhost:3020

# Clerk Publishable Key
# Get this from: https://dashboard.clerk.com/ → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# Electric SQL Proxy URL
# Points to Cloudflare Worker proxy (apps/proxyv2)
# The proxy forwards requests to Electric service
VITE_ELECTRIC_URL=http://localhost:8787/v1/shape

# For production, use deployed Cloudflare Worker URL:
# VITE_ELECTRIC_URL=https://your-worker.your-domain.workers.dev/v1/shape

# NOTE: Direct Electric connection (bypassing proxy):
# VITE_ELECTRIC_URL=http://localhost:5133/v1/shape

# Cloudflare R2 Public URL
# Your CDN URL for public assets
VITE_R2_PUBLIC_URL=https://cdn.your-domain.com
